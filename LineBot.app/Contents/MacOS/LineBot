#!/usr/bin/env bash
# LineBot.app launcher — finds the project root (3 levels up from this script),
# activates the venv, then starts the tkinter control panel.

set -euo pipefail

# ── Resolve paths ────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
VENV_DIR="$PROJECT_ROOT/.venv"
PYTHON="$VENV_DIR/bin/python"

cd "$PROJECT_ROOT"

# ── First-run: venv not yet created → call scripts/setup_mac.sh ─────────────
if [ ! -f "$PYTHON" ]; then
    SETUP="$PROJECT_ROOT/scripts/setup_mac.sh"
    if [ ! -f "$SETUP" ]; then
        osascript -e 'display alert "LINE Bot Setup" message "scripts/setup_mac.sh not found.\nPlease run: bash scripts/setup_mac.sh" as critical'
        exit 1
    fi
    # Open Terminal and run setup, then relaunch the app
    osascript <<EOF
tell application "Terminal"
    activate
    do script "bash '$SETUP' && open '$PROJECT_ROOT/LineBot.app'"
end tell
EOF
    exit 0
fi

# ── Launch GUI ───────────────────────────────────────────────────────────────
exec "$PYTHON" "$PROJECT_ROOT/launcher.py"
