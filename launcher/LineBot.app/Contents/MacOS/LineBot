#!/usr/bin/env bash
# LineBot.app launcher — uses framework Python for tkinter on macOS

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
VENV_PY="$PROJECT_ROOT/.venv/bin/python"

cd "$PROJECT_ROOT"

# First-run: venv not yet created
if [ ! -f "$VENV_PY" ]; then
    SETUP="$PROJECT_ROOT/scripts/setup_mac.sh"
    if [ ! -f "$SETUP" ]; then
        osascript -e 'display alert "LINE Bot Setup" message "scripts/setup_mac.sh not found.\nPlease run: bash scripts/setup_mac.sh" as critical'
        exit 1
    fi
    osascript <<EOF
tell application "Terminal"
    activate
    do script "bash '$SETUP' && open '$PROJECT_ROOT/launcher/LineBot.app'"
end tell
EOF
    exit 0
fi

# Ask the venv Python itself where its framework executable lives
FRAMEWORK_PY=$("$VENV_PY" - <<'PYEOF' 2>/dev/null
import sysconfig, os, glob
prefix = sysconfig.get_config_var("PYTHONFRAMEWORKPREFIX") or ""
candidate = os.path.join(prefix, "Resources/Python.app/Contents/MacOS/Python")
if os.path.isfile(candidate):
    print(candidate)
else:
    patterns = [
        "/opt/homebrew/Cellar/python@3.*/*/Frameworks/Python.framework/Versions/*/Resources/Python.app/Contents/MacOS/Python",
        "/usr/local/Cellar/python@3.*/*/Frameworks/Python.framework/Versions/*/Resources/Python.app/Contents/MacOS/Python",
    ]
    for p in patterns:
        matches = sorted(glob.glob(p), reverse=True)
        if matches:
            print(matches[0])
            break
PYEOF
)

VENV_SITE=$("$VENV_PY" -c "import site; print(site.getsitepackages()[0])" 2>/dev/null || true)

if [ -n "$FRAMEWORK_PY" ] && [ -f "$FRAMEWORK_PY" ] && [ -n "$VENV_SITE" ]; then
    exec env PYTHONPATH="$VENV_SITE" "$FRAMEWORK_PY" "$PROJECT_ROOT/launcher/launcher.py"
fi

exec "$VENV_PY" "$PROJECT_ROOT/launcher/launcher.py"
