# LINE Bot Credentials
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ngrok (optional — for exposing webhook locally)
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# Ollama Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=typhoon2-8b-instruct   # หรือ llama3.2, qwen2.5 ฯลฯ
OLLAMA_EMBED_MODEL=nomic-embed-text

# Faculty Settings
FACULTY_NAME=คณะวิศวกรรมศาสตร์
UNIVERSITY_NAME=มหาวิทยาลัยตัวอย่าง

# RAG Settings
RAG_TOP_K=5                  # จำนวน document chunks ที่ดึงมา
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Conversation
MAX_HISTORY_TURNS=8          # จำนวนรอบการสนทนาที่จำไว้ต่อผู้ใช้
